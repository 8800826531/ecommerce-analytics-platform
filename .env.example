# ── Redpanda Cloud ────────────────────────────────────────────────
REDPANDA_BOOTSTRAP=your-cluster-id.any.us-east-1.mpx.prd.cloud.redpanda.com:9092
REDPANDA_USERNAME=your-service-account-username
REDPANDA_PASSWORD=your-service-account-password
REDPANDA_SCHEMA_REGISTRY_URL=https://your-cluster-id.registry.us-east-1.mpx.prd.cloud.redpanda.com

# ── Databricks CE ─────────────────────────────────────────────────
DATABRICKS_HOST=https://your-workspace-id.cloud.databricks.com
DATABRICKS_TOKEN=your-databricks-token
DATABRICKS_CLUSTER_ID=your-cluster-id

# ── MongoDB Atlas ─────────────────────────────────────────────────
MONGODB_CONNECTION_STRING=mongodb+srv://username:password@cluster.mongodb.net/

# ── Astra DB ──────────────────────────────────────────────────────
ASTRA_CLIENT_ID=your-astra-client-id
ASTRA_CLIENT_SECRET=your-astra-client-secret

# ── GenAI ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key

# ── Project settings ──────────────────────────────────────────────
EVENTS_PER_SECOND=10